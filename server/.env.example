# Copy to .env and fill in your cPanel MySQL values
DB_HOST=localhost
DB_PORT=3306
DB_NAME=your_cpanel_db_name
DB_USER=your_cpanel_db_user
DB_PASS=your_cpanel_db_password

JWT_SECRET=replace_with_a_long_random_string_at_least_32_chars
JWT_EXPIRES_IN=7d

PORT=3001

# URL where uploaded screenshots are served from (your domain)
BASE_URL=https://yourdomain.com
